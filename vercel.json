{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist/frontend",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{build/**/*,node_modules/sqlite3/**/*,config/**/*,data/**/*,i18n/**/*,views/**/*,frontend/dist/frontend/**/*,swagger.yml,ctf.key}",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/rest/:path*",
      "destination": "/api?juicePath=/rest/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api?juicePath=/api/:path*"
    }
  ]
}
